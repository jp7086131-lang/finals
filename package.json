{
  "name": "motobook-api",
  "version": "1.0.0",
  "private": true,
  "description": "MotoBook backend API for food ordering, QR payment, role-based access, and real-time tracking.",
  "main": "server/src/server.js",
  "scripts": {
    "dev": "nodemon server/src/server.js",
    "dev:api": "nodemon server/src/server.js",
    "dev:ui": "vite --host 0.0.0.0 --port 3000",
    "build:ui": "vite build",
    "start": "node server/src/server.js",
    "seed:admin": "node server/src/scripts/seedAdmin.js",
    "reset:rider": "node server/src/scripts/resetRiderPassword.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:server": "node --test server/tests/*.test.js",
    "check": "node --check server/src/server.js"
  },
  "dependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.2.1",
    "firebase": "^12.13.0",
    "firebase-admin": "^13.0.2",
    "framer-motion": "^12.38.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^1.16.0",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "nanoid": "^3.3.8",
    "qrcode": "^1.5.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.3",
    "web-vitals": "^2.1.4",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "nodemon": "^3.1.9",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
